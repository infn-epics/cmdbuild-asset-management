{
    "tabWidth": 4,
    "useTabs": false,
    "semi": true,
    "singleQuote": true,
    "bracketSpacing": true,
    "printWidth": 120,
    "arrowParens": "avoid",
    "endOfLine": "lf",
    "experimentalTernaries": false,
    "quoteProps": "consistent",
    "objectWrap": "preserve",
    "trailingComma": "none"
}
